# Base URL of the Laravel API (no trailing slash). Examples:
# - Android emulator → host machine: http://10.0.2.2:8080
# - iOS Simulator → host machine: http://127.0.0.1:8000
# - Physical device → your LAN IP, e.g. http://192.168.1.10:8000
API_URL=http://127.0.0.1:8000

# Optional: sent as the HTTP `Host` header on every API request (vhost / SNI).
# Example: expenses.local when API_URL uses an IP or different hostname.
# API_HOST=expenses.local

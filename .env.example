# Base URL of the Laravel API (no trailing slash).
#
# iOS Simulator / desktop: http://127.0.0.1:PORT often works (API on same Mac).
#
# Physical iPhone or Android phone: 127.0.0.1 and localhost are the PHONE, so
# you will get "Connection refused". Use your Mac/PC LAN IP instead, same Wi‑Fi:
#   API_URL=http://192.168.1.10:8080
# Your server must listen on 0.0.0.0 (not only 127.0.0.1) so the phone can connect.
#
# Android emulator only (host loopback): http://10.0.2.2:PORT
API_URL=http://127.0.0.1:8000

# Optional: sent as the HTTP `Host` header on every API request (vhost / SNI).
# Example: expenses.local when API_URL uses an IP or different hostname.
# API_HOST=expenses.local
